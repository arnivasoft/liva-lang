// regex::regex — Ergonomic regular expression wrapper API
// Import with: import regex::regex

import std::regex

pub struct Regex {
    var pattern: String
}

impl Regex {
    pub func new(pattern: String) -> Regex {
        return Regex { pattern: pattern }
    }

    pub func isMatch(ref self, text: String) -> bool {
        return regexMatch(text, self.pattern)
    }

    pub func find(ref self, text: String) -> String? {
        return regexFind(text, self.pattern)
    }

    pub func findAll(ref self, text: String) -> [String] {
        return regexFindAll(text, self.pattern)
    }

    pub func replace(ref self, text: String, replacement: String) -> String {
        return regexReplace(text, self.pattern, replacement)
    }

    pub func groups(ref self, text: String) -> [String] {
        return regexFindGroups(text, self.pattern)
    }

    pub func split(ref self, text: String) -> [String] {
        return regexSplit(text, self.pattern)
    }

    pub func toString(ref self) -> String {
        return self.pattern
    }
}
