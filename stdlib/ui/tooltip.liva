// Tooltip — wxWidgets native tooltip wrapper
// Import with: import ui::tooltip

import std::ui

// wxWidgets handles tooltips natively via SetToolTip
// Use: setTooltip(widgetHandle, "Tooltip text")
// Or via the widget struct method: btn.setTooltip("Click here")

pub func applyTooltip(widgetHandle: i32, text: string) {
    setTooltip(widgetHandle, text)
}
