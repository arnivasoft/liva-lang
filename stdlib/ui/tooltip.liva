// Tooltip — wxWidgets native tooltip wrapper
// Import with: import ui::tooltip
import std::ui
import ui::widgets

// wxWidgets handles tooltips natively via SetToolTip.
// Prefer the widget method: widget.setTooltip("...").
// This helper applies a tooltip to any Control.
pub func applyTooltip(c: Control, text: string) {
    c.setTooltip(text)
}
