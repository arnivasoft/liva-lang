pub struct Dropdown {
    var handle: i32
}

impl Dropdown {
    pub func new(parent: i32, choices: string) -> Dropdown {
        return Dropdown { handle: createDropdown(parent, choices) }
    }
    pub func getSelection(ref self) -> i32 { return getValue(self.handle) }
    pub func onSelect(ref self, cb: (i32) -> void) { onSelect(self.handle, cb) }
}

// ── TextArea (wxTextCtrl multiline) ────────────────────────────

pub struct TextArea {
    var handle: i32
}

impl TextArea {
    pub func new(parent: i32, value: string) -> TextArea {
        return TextArea { handle: createTextArea(parent, value) }
    }
    pub func getText(ref self) -> string { return getText(self.handle) }
    pub func setText(ref self, text: string) { setText(self.handle, text) }
    pub func onChange(ref self, cb: (i32) -> void) { onChange(self.handle, cb) }
    pub func setSize(ref self, w: i32, h: i32) { setWidgetSize(self.handle, w, h) }
}

// ── ListBox (wxListBox) ────────────────────────────────────────

pub struct ListBox {
    var handle: i32
}

impl ListBox {
    pub func new(parent: i32) -> ListBox {
        return ListBox { handle: createListBox(parent) }
    }
    pub func addItem(ref self, item: string) { listAddItem(self.handle, item) }
    pub func clear(ref self) { listClear(self.handle) }
    pub func getSelection(ref self) -> i32 { return listGetSelection(self.handle) }
    pub func onSelect(ref self, cb: (i32) -> void) { onSelect(self.handle, cb) }
}

// ── TabView (wxNotebook) ───────────────────────────────────────

pub struct TabView {
    var handle: i32
}

impl TabView {
    pub func new(parent: i32) -> TabView {
        return TabView { handle: createTabView(parent) }
    }
    pub func addPage(ref self, page: i32, title: string) { tabAddPage(self.handle, page, title) }
    pub func getSelection(ref self) -> i32 { return tabGetSelection(self.handle) }
    pub func onSelect(ref self, cb: (i32) -> void) { onSelect(self.handle, cb) }
}

// ── ScrollView (wxScrolledWindow) ──────────────────────────────

pub struct ScrollView {
    var handle: i32
}

impl ScrollView {
    pub func new(parent: i32) -> ScrollView {
        return ScrollView { handle: createScrollView(parent) }
    }
    pub func setSizerHandle(ref self, sizerH: i32) { setSizer(self.handle, sizerH) }
}

// ── ImageView (wxStaticBitmap) ─────────────────────────────────

pub struct ImageView {
    var handle: i32
}

impl ImageView {
    pub func new(parent: i32, path: string) -> ImageView {
        return ImageView { handle: createImageView(parent, path) }
    }
}

// ── Divider (wxStaticLine) ─────────────────────────────────────

pub struct Divider {
    var handle: i32
}

impl Divider {
    pub func new(parent: i32) -> Divider {
        return Divider { handle: createDivider(parent) }
    }
}

// ── Canvas (wxPanel + wxPaintDC) ───────────────────────────────

pub struct Canvas {
    var handle: i32
}

impl Canvas {
    pub func new(parent: i32) -> Canvas {
        return Canvas { handle: createCanvas(parent) }
    }
    pub func onPaint(ref self, cb: (i32) -> void) { canvasOnPaint(self.handle, cb) }
    pub func refresh(ref self) { canvasRefresh(self.handle) }
}

// ── Sizer (layout wrapper) ────────────────────────────────────

pub struct Sizer {
    var handle: i32
}

impl Sizer {
    pub func vbox() -> Sizer { return Sizer { handle: createVBoxSizer() } }
    pub func hbox() -> Sizer { return Sizer { handle: createHBoxSizer() } }
    pub func grid(rows: i32, cols: i32, hgap: i32, vgap: i32) -> Sizer {
        return Sizer { handle: createGridSizer(rows, cols, hgap, vgap) }
    }
    pub func flexGrid(rows: i32, cols: i32, hgap: i32, vgap: i32) -> Sizer {
        return Sizer { handle: createFlexGridSizer(rows, cols, hgap, vgap) }
    }
    pub func add(ref self, widget: i32, proportion: i32, flags: i32, border: i32) {
        sizerAdd(self.handle, widget, proportion, flags, border)
    }
    pub func addSizer(ref self, childH: i32, proportion: i32, flags: i32, border: i32) {
        sizerAdd(self.handle, childH, proportion, flags, border)
    }
}
