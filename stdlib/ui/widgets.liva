// Widget Protocol + Basic Widgets
// Import with: import ui::widgets

import std::ui
import std::convert
import ui::types
import ui::theme

// ---- Widget Protocol ----
pub protocol Widget {
    func getWidth(ref self) -> i32
    func getHeight(ref self) -> i32
    func draw(ref self, x: i32, y: i32)
}

// ---- Utility ----
pub func hitTest(mx: i32, my: i32, x: i32, y: i32, w: i32, h: i32) -> bool {
    return mx >= x && mx <= x + w && my >= y && my <= y + h
}

// ---- Label ----
pub struct Label {
    var text: string
    var fontSize: i32
    var color: Color
}

impl Label {
    func new(text: string, fontSize: i32, color: Color) -> Label {
        return Label { text: text, fontSize: fontSize, color: color }
    }
}

impl Label: Widget {
    func getWidth(ref self) -> i32 {
        return measureText(self.text, self.fontSize)
    }
    func getHeight(ref self) -> i32 {
        return self.fontSize
    }
    func draw(ref self, x: i32, y: i32) {
        drawText(self.text, x, y, self.fontSize,
                 self.color.r, self.color.g, self.color.b, self.color.a)
    }
}

// ---- Button ----
pub struct Button {
    var text: string
    var fontSize: i32
    var color: Color
    var bgColor: Color
    var hoverColor: Color
    var padding: i32
    var id: i32
    var onClick: (i32) -> void
}

impl Button {
    func new(text: string, id: i32) -> Button {
        return Button {
            text: text,
            fontSize: 20,
            color: Color.white(),
            bgColor: Color { r: 80, g: 80, b: 200, a: 255 },
            hoverColor: Color { r: 100, g: 100, b: 230, a: 255 },
            padding: 8,
            id: id,
            onClick: |_id: i32| { }
        }
    }

    func styled(text: string, id: i32, bg: Color, fg: Color) -> Button {
        return Button {
            text: text,
            fontSize: 20,
            color: fg,
            bgColor: bg,
            hoverColor: bg,
            padding: 8,
            id: id,
            onClick: |_id: i32| { }
        }
    }

    func themed(text: string, id: i32, theme: Theme) -> Button {
        return Button {
            text: text,
            fontSize: theme.fontSize,
            color: theme.onPrimary,
            bgColor: theme.primary,
            hoverColor: theme.primaryHover,
            padding: theme.padding,
            id: id,
            onClick: |_id: i32| { }
        }
    }

    func withClick(text: string, id: i32, theme: Theme, cb: (i32) -> void) -> Button {
        return Button {
            text: text,
            fontSize: theme.fontSize,
            color: theme.onPrimary,
            bgColor: theme.primary,
            hoverColor: theme.primaryHover,
            padding: theme.padding,
            id: id,
            onClick: cb
        }
    }

    func isHovered(ref self, bx: i32, by: i32) -> bool {
        let w = measureText(self.text, self.fontSize) + self.padding * 2
        let h = self.fontSize + self.padding * 2
        return hitTest(getMouseX(), getMouseY(), bx, by, w, h)
    }

    func isClicked(ref self, bx: i32, by: i32) -> bool {
        return self.isHovered(bx, by) && isMousePressed(0)
    }

    func update(ref self, bx: i32, by: i32) {
        if self.isClicked(bx, by) {
            self.onClick(self.id)
        }
    }

    func setOnClick(ref mut self, cb: (i32) -> void) {
        self.onClick = cb
    }
}

impl Button: Widget {
    func getWidth(ref self) -> i32 {
        return measureText(self.text, self.fontSize) + self.padding * 2
    }
    func getHeight(ref self) -> i32 {
        return self.fontSize + self.padding * 2
    }
    func draw(ref self, x: i32, y: i32) {
        let w = self.getWidth()
        let h = self.getHeight()
        let hovered = hitTest(getMouseX(), getMouseY(), x, y, w, h)
        if hovered {
            let hc = self.hoverColor
            drawRect(x, y, w, h, hc.r, hc.g, hc.b, hc.a)
        } else {
            let bg = self.bgColor
            drawRect(x, y, w, h, bg.r, bg.g, bg.b, bg.a)
        }
        drawText(self.text, x + self.padding, y + self.padding,
                 self.fontSize, self.color.r, self.color.g, self.color.b, self.color.a)
    }
}

// ---- Spacer ----
pub struct Spacer {
    var w: i32
    var h: i32
}

impl Spacer {
    func new(w: i32, h: i32) -> Spacer {
        return Spacer { w: w, h: h }
    }
    func vertical(h: i32) -> Spacer {
        return Spacer { w: 0, h: h }
    }
    func horizontal(w: i32) -> Spacer {
        return Spacer { w: w, h: 0 }
    }
}

impl Spacer: Widget {
    func getWidth(ref self) -> i32 { return self.w }
    func getHeight(ref self) -> i32 { return self.h }
    func draw(ref self, x: i32, y: i32) { }
}

// ---- Panel ----
pub struct Panel {
    var bgColor: Color
    var padding: i32
    var contentW: i32
    var contentH: i32
    var rounded: bool
}

impl Panel {
    func new(bgColor: Color, padding: i32, contentW: i32, contentH: i32) -> Panel {
        return Panel {
            bgColor: bgColor, padding: padding,
            contentW: contentW, contentH: contentH, rounded: false
        }
    }

    func themed(theme: Theme, padding: i32, contentW: i32, contentH: i32) -> Panel {
        return Panel {
            bgColor: theme.surface, padding: padding,
            contentW: contentW, contentH: contentH, rounded: true
        }
    }
}

impl Panel: Widget {
    func getWidth(ref self) -> i32 { return self.contentW + self.padding * 2 }
    func getHeight(ref self) -> i32 { return self.contentH + self.padding * 2 }
    func draw(ref self, x: i32, y: i32) {
        let w = self.getWidth()
        let h = self.getHeight()
        if self.rounded {
            drawRectRounded(x, y, w, h, 0.1, self.bgColor.r, self.bgColor.g, self.bgColor.b, self.bgColor.a)
        } else {
            drawRect(x, y, w, h,
                     self.bgColor.r, self.bgColor.g, self.bgColor.b, self.bgColor.a)
        }
    }
}

// ---- Divider ----
pub struct Divider {
    var length: i32
    var thickness: i32
    var color: Color
    var horizontal: bool
}

impl Divider {
    func horizontalLine(length: i32, color: Color) -> Divider {
        return Divider { length: length, thickness: 1, color: color, horizontal: true }
    }
    func verticalLine(length: i32, color: Color) -> Divider {
        return Divider { length: length, thickness: 1, color: color, horizontal: false }
    }
    func themedHorizontal(length: i32, theme: Theme) -> Divider {
        return Divider { length: length, thickness: 1, color: theme.divider, horizontal: true }
    }
    func themedVertical(length: i32, theme: Theme) -> Divider {
        return Divider { length: length, thickness: 1, color: theme.divider, horizontal: false }
    }
}

impl Divider: Widget {
    func getWidth(ref self) -> i32 {
        if self.horizontal { return self.length }
        return self.thickness
    }
    func getHeight(ref self) -> i32 {
        if self.horizontal { return self.thickness }
        return self.length
    }
    func draw(ref self, x: i32, y: i32) {
        if self.horizontal {
            drawLine(x, y, x + self.length, y,
                     self.color.r, self.color.g, self.color.b, self.color.a)
        } else {
            drawLine(x, y, x, y + self.length,
                     self.color.r, self.color.g, self.color.b, self.color.a)
        }
    }
}

// ---- TextInput ----
pub struct TextInput {
    var value: string
    var placeholder: string
    var fontSize: i32
    var width: i32
    var cursorPos: i32
    var focused: bool
    var bgColor: Color
    var textColor: Color
    var borderColor: Color
    var focusedBorderColor: Color
    var placeholderColor: Color
    var cursorColor: Color
    var padding: i32
}

impl TextInput {
    func new(placeholder: string, width: i32) -> TextInput {
        return TextInput {
            value: "",
            placeholder: placeholder,
            fontSize: 20,
            width: width,
            cursorPos: 0,
            focused: false,
            bgColor: Color { r: 40, g: 40, b: 40, a: 255 },
            textColor: Color.white(),
            borderColor: Color { r: 100, g: 100, b: 100, a: 255 },
            focusedBorderColor: Color { r: 100, g: 150, b: 255, a: 255 },
            placeholderColor: Color { r: 120, g: 120, b: 120, a: 255 },
            cursorColor: Color { r: 255, g: 255, b: 255, a: 255 },
            padding: 6
        }
    }

    func themed(placeholder: string, width: i32, theme: Theme) -> TextInput {
        return TextInput {
            value: "",
            placeholder: placeholder,
            fontSize: theme.fontSize,
            width: width,
            cursorPos: 0,
            focused: false,
            bgColor: theme.surfaceAlt,
            textColor: theme.text,
            borderColor: theme.border,
            focusedBorderColor: theme.borderFocused,
            placeholderColor: theme.textSecondary,
            cursorColor: theme.text,
            padding: theme.padding
        }
    }

    func update(ref mut self, x: i32, y: i32) {
        let h = self.fontSize + self.padding * 2
        // Click to focus
        if isMousePressed(0) {
            if hitTest(getMouseX(), getMouseY(), x, y, self.width, h) {
                self.focused = true
                // Estimate cursor position from click X
                let clickX = getMouseX() - x - self.padding
                let textLen = len(self.value) as i32
                var pos = textLen
                var i = 0
                while i <= textLen {
                    let tw = measureText(self.value.substring(0, i), self.fontSize)
                    if tw >= clickX {
                        pos = i
                        i = textLen + 1
                    } else {
                        i = i + 1
                    }
                }
                self.cursorPos = pos
            } else {
                self.focused = false
            }
        }
        if !self.focused { return }
        // Character input
        var ch = getCharPressed()
        while ch > 0 {
            if ch >= 32 && ch < 127 {
                let vlen = len(self.value) as i32
                let before = self.value.substring(0, self.cursorPos)
                let after = self.value.substring(self.cursorPos, vlen - self.cursorPos)
                let charStr = charToString(ch)
                self.value = before + charStr + after
                self.cursorPos = self.cursorPos + 1
            }
            ch = getCharPressed()
        }
        // Backspace
        if isKeyPressed(259) {
            if self.cursorPos > 0 {
                let vlen = len(self.value) as i32
                let before = self.value.substring(0, self.cursorPos - 1)
                let after = self.value.substring(self.cursorPos, vlen - self.cursorPos)
                self.value = before + after
                self.cursorPos = self.cursorPos - 1
            }
        }
        // Delete
        if isKeyPressed(261) {
            let vlen = len(self.value) as i32
            if self.cursorPos < vlen {
                let before = self.value.substring(0, self.cursorPos)
                let after = self.value.substring(self.cursorPos + 1, vlen - self.cursorPos - 1)
                self.value = before + after
            }
        }
        // Left arrow
        if isKeyPressed(263) {
            if self.cursorPos > 0 {
                self.cursorPos = self.cursorPos - 1
            }
        }
        // Right arrow
        if isKeyPressed(262) {
            if self.cursorPos < (len(self.value) as i32) {
                self.cursorPos = self.cursorPos + 1
            }
        }
        // Home
        if isKeyPressed(268) {
            self.cursorPos = 0
        }
        // End
        if isKeyPressed(269) {
            self.cursorPos = len(self.value) as i32
        }
    }

    func getText(ref self) -> string { return self.value }
}

impl TextInput: Widget {
    func getWidth(ref self) -> i32 { return self.width }
    func getHeight(ref self) -> i32 { return self.fontSize + self.padding * 2 }
    func draw(ref self, x: i32, y: i32) {
        let w = self.width
        let h = self.getHeight()
        // Background
        drawRect(x, y, w, h, self.bgColor.r, self.bgColor.g, self.bgColor.b, self.bgColor.a)
        // Border
        if self.focused {
            let fbc = self.focusedBorderColor
            drawRectLines(x, y, w, h, fbc.r, fbc.g, fbc.b, fbc.a)
        } else {
            let bc = self.borderColor
            drawRectLines(x, y, w, h, bc.r, bc.g, bc.b, bc.a)
        }
        // Text or placeholder
        let textY = y + self.padding
        let textX = x + self.padding
        if (len(self.value) as i32) > 0 {
            drawText(self.value, textX, textY, self.fontSize,
                     self.textColor.r, self.textColor.g, self.textColor.b, self.textColor.a)
        } else {
            let pc = self.placeholderColor
            drawText(self.placeholder, textX, textY, self.fontSize, pc.r, pc.g, pc.b, pc.a)
        }
        // Cursor (simple line)
        if self.focused {
            let cursorX = textX + measureText(self.value.substring(0, self.cursorPos), self.fontSize)
            let cc = self.cursorColor
            drawLine(cursorX, y + 3, cursorX, y + h - 3, cc.r, cc.g, cc.b, cc.a)
        }
    }
}

// ---- Checkbox ----
pub struct Checkbox {
    var label: string
    var checked: bool
    var fontSize: i32
    var color: Color
    var checkColor: Color
    var boxSize: i32
    var onToggle: (bool) -> void
}

impl Checkbox {
    func new(label: string, checked: bool) -> Checkbox {
        return Checkbox {
            label: label,
            checked: checked,
            fontSize: 20,
            color: Color.white(),
            checkColor: Color { r: 80, g: 200, b: 80, a: 255 },
            boxSize: 20,
            onToggle: |_v: bool| { }
        }
    }

    func themed(label: string, checked: bool, theme: Theme) -> Checkbox {
        return Checkbox {
            label: label,
            checked: checked,
            fontSize: theme.fontSize,
            color: theme.text,
            checkColor: theme.success,
            boxSize: theme.fontSize,
            onToggle: |_v: bool| { }
        }
    }

    func withToggle(label: string, checked: bool, theme: Theme, cb: (bool) -> void) -> Checkbox {
        return Checkbox {
            label: label,
            checked: checked,
            fontSize: theme.fontSize,
            color: theme.text,
            checkColor: theme.success,
            boxSize: theme.fontSize,
            onToggle: cb
        }
    }

    func update(ref mut self, x: i32, y: i32) {
        let totalW = self.boxSize + 8 + measureText(self.label, self.fontSize)
        if isMousePressed(0) {
            if hitTest(getMouseX(), getMouseY(), x, y, totalW, self.boxSize) {
                self.checked = !self.checked
                self.onToggle(self.checked)
            }
        }
    }

    func isChecked(ref self) -> bool { return self.checked }

    func setOnToggle(ref mut self, cb: (bool) -> void) {
        self.onToggle = cb
    }
}

impl Checkbox: Widget {
    func getWidth(ref self) -> i32 {
        return self.boxSize + 8 + measureText(self.label, self.fontSize)
    }
    func getHeight(ref self) -> i32 { return self.boxSize }
    func draw(ref self, x: i32, y: i32) {
        let bs = self.boxSize
        // Box border
        drawRectLines(x, y, bs, bs, self.color.r, self.color.g, self.color.b, self.color.a)
        // Check mark (filled inner rect)
        if self.checked {
            let cc = self.checkColor
            drawRect(x + 2, y + 3, bs - 6, bs - 6, cc.r, cc.g, cc.b, cc.a)
        }
        // Label
        drawText(self.label, x + bs + 8, y, self.fontSize,
                 self.color.r, self.color.g, self.color.b, self.color.a)
    }
}

// ---- Slider ----
pub struct Slider {
    var value: i32
    var minVal: i32
    var maxVal: i32
    var width: i32
    var height: i32
    var trackColor: Color
    var thumbColor: Color
    var dragging: bool
    var onValueChange: (i32) -> void
}

impl Slider {
    func new(minVal: i32, maxVal: i32, width: i32) -> Slider {
        return Slider {
            value: minVal,
            minVal: minVal,
            maxVal: maxVal,
            width: width,
            height: 20,
            trackColor: Color { r: 60, g: 60, b: 60, a: 255 },
            thumbColor: Color { r: 100, g: 150, b: 255, a: 255 },
            dragging: false,
            onValueChange: |_v: i32| { }
        }
    }

    func themed(minVal: i32, maxVal: i32, width: i32, theme: Theme) -> Slider {
        return Slider {
            value: minVal,
            minVal: minVal,
            maxVal: maxVal,
            width: width,
            height: theme.fontSize,
            trackColor: theme.surfaceAlt,
            thumbColor: theme.primary,
            dragging: false,
            onValueChange: |_v: i32| { }
        }
    }

    func withChange(minVal: i32, maxVal: i32, width: i32, theme: Theme, cb: (i32) -> void) -> Slider {
        return Slider {
            value: minVal,
            minVal: minVal,
            maxVal: maxVal,
            width: width,
            height: theme.fontSize,
            trackColor: theme.surfaceAlt,
            thumbColor: theme.primary,
            dragging: false,
            onValueChange: cb
        }
    }

    func update(ref mut self, x: i32, y: i32) {
        let mx = getMouseX()
        let my = getMouseY()
        if isMousePressed(0) {
            if hitTest(mx, my, x, y, self.width, self.height) {
                self.dragging = true
            }
        }
        if isMouseReleased(0) {
            self.dragging = false
        }
        if self.dragging {
            let relX = mx - x
            let range = self.maxVal - self.minVal
            var newVal = self.minVal + (relX * range) / self.width
            if newVal < self.minVal { newVal = self.minVal }
            if newVal > self.maxVal { newVal = self.maxVal }
            if newVal != self.value {
                self.value = newVal
                self.onValueChange(self.value)
            }
        }
    }

    func getValue(ref self) -> i32 { return self.value }

    func setOnChange(ref mut self, cb: (i32) -> void) {
        self.onValueChange = cb
    }
}

impl Slider: Widget {
    func getWidth(ref self) -> i32 { return self.width }
    func getHeight(ref self) -> i32 { return self.height }
    func draw(ref self, x: i32, y: i32) {
        let w = self.width
        let h = self.height
        let tc = self.trackColor
        // Track background
        drawRect(x, y + h / 2 - 2, w, 4, tc.r, tc.g, tc.b, tc.a)
        // Thumb position
        let range = self.maxVal - self.minVal
        var thumbX = x
        if range > 0 {
            thumbX = x + ((self.value - self.minVal) * (w - 12)) / range
        }
        let thc = self.thumbColor
        drawRect(thumbX, y, 12, h, thc.r, thc.g, thc.b, thc.a)
    }
}

// ---- ScrollView ----
pub struct ScrollView {
    var viewWidth: i32
    var viewHeight: i32
    var contentHeight: i32
    var scrollY: i32
    var bgColor: Color
    var scrollSpeed: i32
}

impl ScrollView {
    func new(viewWidth: i32, viewHeight: i32, contentHeight: i32) -> ScrollView {
        return ScrollView {
            viewWidth: viewWidth,
            viewHeight: viewHeight,
            contentHeight: contentHeight,
            scrollY: 0,
            bgColor: Color { r: 30, g: 30, b: 30, a: 255 },
            scrollSpeed: 30
        }
    }

    func themed(viewWidth: i32, viewHeight: i32, contentHeight: i32, theme: Theme) -> ScrollView {
        return ScrollView {
            viewWidth: viewWidth,
            viewHeight: viewHeight,
            contentHeight: contentHeight,
            scrollY: 0,
            bgColor: theme.background,
            scrollSpeed: theme.scrollSpeed
        }
    }

    func update(ref mut self, x: i32, y: i32) {
        let mx = getMouseX()
        let my = getMouseY()
        if hitTest(mx, my, x, y, self.viewWidth, self.viewHeight) {
            let wheel = getMouseWheel()
            self.scrollY = self.scrollY - wheel * self.scrollSpeed
            // Clamp
            if self.scrollY < 0 { self.scrollY = 0 }
            let maxScroll = self.contentHeight - self.viewHeight
            if maxScroll < 0 {
                self.scrollY = 0
            } else {
                if self.scrollY > maxScroll { self.scrollY = maxScroll }
            }
        }
    }

    func beginDraw(ref self, x: i32, y: i32) {
        let bg = self.bgColor
        drawRect(x, y, self.viewWidth, self.viewHeight, bg.r, bg.g, bg.b, bg.a)
        beginScissor(x, y, self.viewWidth, self.viewHeight)
    }

    func endDraw(ref self) {
        endScissor()
    }

    func getScrollY(ref self) -> i32 { return self.scrollY }
}

impl ScrollView: Widget {
    func getWidth(ref self) -> i32 { return self.viewWidth }
    func getHeight(ref self) -> i32 { return self.viewHeight }
    func draw(ref self, x: i32, y: i32) {
        let bg = self.bgColor
        drawRect(x, y, self.viewWidth, self.viewHeight, bg.r, bg.g, bg.b, bg.a)
    }
}

// ---- ProgressBar ----
pub struct ProgressBar {
    var value: i32
    var width: i32
    var height: i32
    var bgColor: Color
    var fillColor: Color
    var borderColor: Color
}

impl ProgressBar {
    func new(width: i32, height: i32) -> ProgressBar {
        return ProgressBar {
            value: 0,
            width: width,
            height: height,
            bgColor: Color { r: 50, g: 50, b: 50, a: 255 },
            fillColor: Color { r: 80, g: 180, b: 80, a: 255 },
            borderColor: Color { r: 80, g: 80, b: 80, a: 255 }
        }
    }

    func themed(width: i32, height: i32, theme: Theme) -> ProgressBar {
        return ProgressBar {
            value: 0,
            width: width,
            height: height,
            bgColor: theme.surface,
            fillColor: theme.success,
            borderColor: theme.border
        }
    }

    func setValue(ref mut self, val: i32) {
        if val < 0 { self.value = 0 }
        else {
            if val > 100 { self.value = 100 }
            else { self.value = val }
        }
    }
}

impl ProgressBar: Widget {
    func getWidth(ref self) -> i32 { return self.width }
    func getHeight(ref self) -> i32 { return self.height }
    func draw(ref self, x: i32, y: i32) {
        let w = self.width
        let h = self.height
        let bg = self.bgColor
        drawRect(x, y, w, h, bg.r, bg.g, bg.b, bg.a)
        // Filled portion
        let fillW = (w * self.value) / 100
        if fillW > 0 {
            let fc = self.fillColor
            drawRect(x, y, fillW, h, fc.r, fc.g, fc.b, fc.a)
        }
        // Border
        let bdc = self.borderColor
        drawRectLines(x, y, w, h, bdc.r, bdc.g, bdc.b, bdc.a)
    }
}

// ---- RadioGroup ----
pub struct RadioGroup {
    var opt0: string
    var opt1: string
    var opt2: string
    var opt3: string
    var opt4: string
    var opt5: string
    var opt6: string
    var opt7: string
    var count: i32
    var selected: i32
    var fontSize: i32
    var textColor: Color
    var radioColor: Color
    var selectedColor: Color
    var radioSize: i32
    var spacing: i32
    var onSelect: (i32) -> void
}

impl RadioGroup {
    func of2(a: string, b: string) -> RadioGroup {
        return RadioGroup {
            opt0: a, opt1: b, opt2: "", opt3: "",
            opt4: "", opt5: "", opt6: "", opt7: "",
            count: 2, selected: -1, fontSize: 20,
            textColor: Color.white(),
            radioColor: Color { r: 100, g: 100, b: 100, a: 255 },
