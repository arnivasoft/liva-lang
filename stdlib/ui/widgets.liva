pub struct RadioGroup {
    var handle: i32
}

impl RadioGroup {
    pub func new(parent: i32, choices: string) -> RadioGroup {
        return RadioGroup { handle: createRadioGroup(parent, choices) }
    }
    pub func getSelection(ref self) -> i32 { return getValue(self.handle) }
    pub func onSelect(ref self, cb: (i32) -> void) { onSelect(self.handle, cb) }
}

