    func themed2(a: string, b: string, theme: Theme) -> RadioGroup {
        return RadioGroup {
            opt0: a, opt1: b, opt2: "", opt3: "",
            opt4: "", opt5: "", opt6: "", opt7: "",
            count: 2, selected: -1, fontSize: theme.fontSize,
            textColor: theme.text,
            radioColor: theme.border,
            selectedColor: theme.primary,
            radioSize: 18, spacing: theme.spacing,
            onSelect: |_i: i32| { }
        }
    }

    func themed3(a: string, b: string, c: string, theme: Theme) -> RadioGroup {
        return RadioGroup {
            opt0: a, opt1: b, opt2: c, opt3: "",
            opt4: "", opt5: "", opt6: "", opt7: "",
            count: 3, selected: -1, fontSize: theme.fontSize,
            textColor: theme.text,
            radioColor: theme.border,
            selectedColor: theme.primary,
            radioSize: 18, spacing: theme.spacing,
            onSelect: |_i: i32| { }
        }
    }

    func themed4(a: string, b: string, c: string, d: string, theme: Theme) -> RadioGroup {
        return RadioGroup {
            opt0: a, opt1: b, opt2: c, opt3: d,
            opt4: "", opt5: "", opt6: "", opt7: "",
            count: 4, selected: -1, fontSize: theme.fontSize,
            textColor: theme.text,
            radioColor: theme.border,
            selectedColor: theme.primary,
            radioSize: 18, spacing: theme.spacing,
            onSelect: |_i: i32| { }
        }
    }

    func themed5(a: string, b: string, c: string, d: string, e: string, theme: Theme) -> RadioGroup {
        return RadioGroup {
            opt0: a, opt1: b, opt2: c, opt3: d,
            opt4: e, opt5: "", opt6: "", opt7: "",
            count: 5, selected: -1, fontSize: theme.fontSize,
            textColor: theme.text,
            radioColor: theme.border,
            selectedColor: theme.primary,
            radioSize: 18, spacing: theme.spacing,
            onSelect: |_i: i32| { }
        }
    }

    func getOption(ref self, idx: i32) -> string {
        if idx == 0 { return self.opt0 }
        if idx == 1 { return self.opt1 }
        if idx == 2 { return self.opt2 }
        if idx == 3 { return self.opt3 }
        if idx == 4 { return self.opt4 }
        if idx == 5 { return self.opt5 }
        if idx == 6 { return self.opt6 }
        if idx == 7 { return self.opt7 }
        return ""
    }

    func getSelected(ref self) -> i32 { return self.selected }

    func setOnSelect(ref mut self, cb: (i32) -> void) {
        self.onSelect = cb
    }

    func update(ref mut self, x: i32, y: i32) {
        if isMousePressed(0) {
            let mx = getMouseX()
            let my = getMouseY()
            var i = 0
            while i < self.count {
                let rowY = y + i * (self.radioSize + self.spacing)
                let rowW = self.radioSize + 208
                if hitTest(mx, my, x, rowY, rowW, self.radioSize) {
                    if i != self.selected {
                        self.selected = i
                        self.onSelect(i)
                    }
                }
                i = i + 1
            }
        }
    }
}

impl RadioGroup: Widget {
    func getWidth(ref self) -> i32 {
        var maxW = 0
        var i = 0
        while i < self.count {
            let optText = self.getOption(i)
            let w = self.radioSize + 8 + measureText(optText, self.fontSize)
            if w > maxW { maxW = w }
            i = i + 1
        }
        return maxW
    }

    func getHeight(ref self) -> i32 {
        if self.count <= 0 { return 0 }
        return self.count * self.radioSize + (self.count - 1) * self.spacing
    }

    func draw(ref self, x: i32, y: i32) {
        var i = 0
        while i < self.count {
            let rowY = y + i * (self.radioSize + self.spacing)
            let cx = x + self.radioSize / 2
            let cy = rowY + self.radioSize / 2
            let outerR = self.radioSize / 2
            // Outer circle (ring)
            let rc = self.radioColor
            drawCircle(cx, cy, outerR, rc.r, rc.g, rc.b, rc.a)
            // Inner circle (creates ring effect)
            drawCircle(cx, cy, outerR - 2, 30, 30, 30, 255)
            // Selected dot
            if i == self.selected {
                let sc = self.selectedColor
                drawCircle(cx, cy, outerR / 2, sc.r, sc.g, sc.b, sc.a)
            }
            // Label text
            let optText = self.getOption(i)
            let tc = self.textColor
            drawText(optText, x + self.radioSize + 8, rowY, self.fontSize,
                     tc.r, tc.g, tc.b, tc.a)
            i = i + 1
        }
    }
}

// ---- TabView ----
pub struct TabView {
    var tab0: string
    var tab1: string
    var tab2: string
    var tab3: string
    var tab4: string
    var tab5: string
    var tab6: string
    var tab7: string
    var count: i32
    var selected: i32
    var fontSize: i32
    var textColor: Color
    var activeTextColor: Color
    var activeColor: Color
    var inactiveColor: Color
    var indicatorColor: Color
    var padding: i32
    var tabSpacing: i32
    var onTabChange: (i32) -> void
}

impl TabView {
    func of2(a: string, b: string) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: "", tab3: "",
            tab4: "", tab5: "", tab6: "", tab7: "",
            count: 2, selected: 0, fontSize: 20,
            textColor: Color { r: 180, g: 180, b: 180, a: 255 },
            activeTextColor: Color.white(),
            activeColor: Color { r: 50, g: 50, b: 80, a: 255 },
            inactiveColor: Color { r: 40, g: 40, b: 40, a: 255 },
            indicatorColor: Color { r: 80, g: 150, b: 255, a: 255 },
            padding: 8, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func of3(a: string, b: string, c: string) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: c, tab3: "",
            tab4: "", tab5: "", tab6: "", tab7: "",
            count: 3, selected: 0, fontSize: 20,
            textColor: Color { r: 180, g: 180, b: 180, a: 255 },
            activeTextColor: Color.white(),
            activeColor: Color { r: 50, g: 50, b: 80, a: 255 },
            inactiveColor: Color { r: 40, g: 40, b: 40, a: 255 },
            indicatorColor: Color { r: 80, g: 150, b: 255, a: 255 },
            padding: 8, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func of4(a: string, b: string, c: string, d: string) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: c, tab3: d,
            tab4: "", tab5: "", tab6: "", tab7: "",
            count: 4, selected: 0, fontSize: 20,
            textColor: Color { r: 180, g: 180, b: 180, a: 255 },
            activeTextColor: Color.white(),
            activeColor: Color { r: 50, g: 50, b: 80, a: 255 },
            inactiveColor: Color { r: 40, g: 40, b: 40, a: 255 },
            indicatorColor: Color { r: 80, g: 150, b: 255, a: 255 },
            padding: 8, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func of5(a: string, b: string, c: string, d: string, e: string) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: c, tab3: d,
            tab4: e, tab5: "", tab6: "", tab7: "",
            count: 5, selected: 0, fontSize: 20,
            textColor: Color { r: 180, g: 180, b: 180, a: 255 },
            activeTextColor: Color.white(),
            activeColor: Color { r: 50, g: 50, b: 80, a: 255 },
            inactiveColor: Color { r: 40, g: 40, b: 40, a: 255 },
            indicatorColor: Color { r: 80, g: 150, b: 255, a: 255 },
            padding: 8, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func themed2(a: string, b: string, theme: Theme) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: "", tab3: "",
            tab4: "", tab5: "", tab6: "", tab7: "",
            count: 2, selected: 0, fontSize: theme.fontSize,
            textColor: theme.textSecondary,
            activeTextColor: theme.text,
            activeColor: theme.surface,
            inactiveColor: theme.surfaceAlt,
            indicatorColor: theme.primary,
            padding: theme.padding, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func themed3(a: string, b: string, c: string, theme: Theme) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: c, tab3: "",
            tab4: "", tab5: "", tab6: "", tab7: "",
            count: 3, selected: 0, fontSize: theme.fontSize,
            textColor: theme.textSecondary,
            activeTextColor: theme.text,
            activeColor: theme.surface,
            inactiveColor: theme.surfaceAlt,
            indicatorColor: theme.primary,
            padding: theme.padding, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func themed4(a: string, b: string, c: string, d: string, theme: Theme) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: c, tab3: d,
            tab4: "", tab5: "", tab6: "", tab7: "",
            count: 4, selected: 0, fontSize: theme.fontSize,
            textColor: theme.textSecondary,
            activeTextColor: theme.text,
            activeColor: theme.surface,
            inactiveColor: theme.surfaceAlt,
            indicatorColor: theme.primary,
            padding: theme.padding, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func themed5(a: string, b: string, c: string, d: string, e: string, theme: Theme) -> TabView {
        return TabView {
            tab0: a, tab1: b, tab2: c, tab3: d,
            tab4: e, tab5: "", tab6: "", tab7: "",
            count: 5, selected: 0, fontSize: theme.fontSize,
            textColor: theme.textSecondary,
            activeTextColor: theme.text,
            activeColor: theme.surface,
            inactiveColor: theme.surfaceAlt,
            indicatorColor: theme.primary,
            padding: theme.padding, tabSpacing: 2,
            onTabChange: |_i: i32| { }
        }
    }

    func getTab(ref self, idx: i32) -> string {
        if idx == 0 { return self.tab0 }
        if idx == 1 { return self.tab1 }
        if idx == 2 { return self.tab2 }
        if idx == 3 { return self.tab3 }
        if idx == 4 { return self.tab4 }
        if idx == 5 { return self.tab5 }
        if idx == 6 { return self.tab6 }
        if idx == 7 { return self.tab7 }
        return ""
    }

    func getSelected(ref self) -> i32 { return self.selected }

    func setOnTabChange(ref mut self, cb: (i32) -> void) {
        self.onTabChange = cb
    }

    func getTabWidth(ref self, idx: i32) -> i32 {
        let tabLabel = self.getTab(idx)
        return measureText(tabLabel, self.fontSize) + self.padding * 2
    }

    func update(ref mut self, x: i32, y: i32) {
        if isMousePressed(0) {
            let mx = getMouseX()
            let my = getMouseY()
            let tabH = self.fontSize + self.padding * 2
            var tabX = x
            var i = 0
            while i < self.count {
                // Inline tab width: measureText + padding*2
                var tw = self.padding * 2
                if i == 0 { tw = tw + measureText(self.tab0, self.fontSize) }
                if i == 1 { tw = tw + measureText(self.tab1, self.fontSize) }
                if i == 2 { tw = tw + measureText(self.tab2, self.fontSize) }
                if i == 3 { tw = tw + measureText(self.tab3, self.fontSize) }
                if i == 4 { tw = tw + measureText(self.tab4, self.fontSize) }
                if i == 5 { tw = tw + measureText(self.tab5, self.fontSize) }
                if i == 6 { tw = tw + measureText(self.tab6, self.fontSize) }
                if i == 7 { tw = tw + measureText(self.tab7, self.fontSize) }
                if hitTest(mx, my, tabX, y, tw, tabH) {
                    if i != self.selected {
                        self.selected = i
                        self.onTabChange(i)
                    }
                }
                tabX = tabX + tw + self.tabSpacing
                i = i + 1
            }
        }
    }
}

impl TabView: Widget {
    func getWidth(ref self) -> i32 {
        var total = 0
        var i = 0
        while i < self.count {
            total = total + self.getTabWidth(i)
            if i < self.count - 1 {
                total = total + self.tabSpacing
            }
            i = i + 1
        }
        return total
    }

    func getHeight(ref self) -> i32 {
        return self.fontSize + self.padding * 2
    }

    func draw(ref self, x: i32, y: i32) {
        let tabH = self.fontSize + self.padding * 2
        var tabX = x
        var i = 0
        while i < self.count {
            let tw = self.getTabWidth(i)
            let tabLabel = self.getTab(i)
            if i == self.selected {
                let ac = self.activeColor
                drawRect(tabX, y, tw, tabH, ac.r, ac.g, ac.b, ac.a)
                let atc = self.activeTextColor
                drawText(tabLabel, tabX + self.padding, y + self.padding,
                         self.fontSize, atc.r, atc.g, atc.b, atc.a)
                // Active indicator line
                let ic = self.indicatorColor
                drawRect(tabX, y + tabH - 3, tw, 3, ic.r, ic.g, ic.b, ic.a)
            } else {
                let ic2 = self.inactiveColor
                drawRect(tabX, y, tw, tabH, ic2.r, ic2.g, ic2.b, ic2.a)
                let tc = self.textColor
                drawText(tabLabel, tabX + self.padding, y + self.padding,
                         self.fontSize, tc.r, tc.g, tc.b, tc.a)
            }
            tabX = tabX + tw + self.tabSpacing
            i = i + 1
        }
    }
}

// ---- Dropdown ----
pub struct Dropdown {
    var opt0: string
    var opt1: string
    var opt2: string
    var opt3: string
    var opt4: string
    var opt5: string
    var opt6: string
    var opt7: string
    var count: i32
    var selected: i32
    var open: bool
    var hoverIndex: i32
    var width: i32
    var fontSize: i32
