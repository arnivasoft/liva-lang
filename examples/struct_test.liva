struct Point {
    var x: i32
    var y: i32
}

impl Point {
    func sum(self) -> i32 {
        return self.x + self.y
    }
}

func main() {
    var p = Point { x: 10, y: 20 }
    println(p.x)
    println(p.y)

    p.x = 42
    println(p.x)

    let s = p.sum()
    println(s)

    for i in 0..5 {
        println(i)
    }
}
