// Basic Hello World — wxWidgets window with label
import ui::widgets
import ui::types

func main() {
    appInit()

    let win = Window(800, 600, "Liva UI Demo")
    let panel = Panel(win)
    panel.setBgColor(30, 30, 30)

    let sizer = createVBoxSizer()
    let lbl = Label(panel, "Hello from Liva!")
    lbl.setFont(24, false)
    lbl.setFgColor(255, 255, 255)
    sizerAdd(sizer, lbl.handle, 0, WX_ALL(), 20)

    panel.setSizerHandle(sizer)
    win.show()
    appRun()
}
