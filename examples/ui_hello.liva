// Basic Hello World — wxWidgets window with label
import std::ui
import ui::types

func main() {
    appInit()

    let win = createWindow(800, 600, "Liva UI Demo")
    let panel = createPanel(win)
    setBgColor(panel, 30, 30, 30)

    let sizer = createVBoxSizer()
    let lbl = createLabel(panel, "Hello from Liva!")
    setWidgetFont(lbl, 24, 0)
    setFgColor(lbl, 255, 255, 255)
    sizerAdd(sizer, lbl, 0, WX_ALL(), 20)

    setSizer(panel, sizer)
    windowShow(win, 1)
    appRun()
}
