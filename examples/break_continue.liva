// Break/Continue integration test

func main() {
    // Test 1: break in while loop - should print 5
    var i: i32 = 0
    while i < 10 {
        if i == 5 { break }
        i = i + 1
    }
    println(i)

    // Test 2: continue in for loop - should print 42 (0+1+2+4+5+6+7+8+9 = 42)
    var sum: i32 = 0
    for j in 0..10 {
        if j == 3 { continue }
        sum = sum + j
    }
    println(sum)
}
