// Input Validation Demo — Form validation with status feedback
// Build: livac examples/ui_validation_demo.liva -o validation_demo

import ui::widgets
import ui::types

func main() {
    appInit()

    let win = Window(450, 400, "Form Dogrulama")
    let panel = Panel(win)

    let sizer = createVBoxSizer()

    let title = Label(panel, "Kayit Dogrulama Formu")
    title.setFont(16, true)
    sizerAdd(sizer, title.handle, 0, WX_ALL(), 10)

    // Name field
    let nameLbl = Label(panel, "Ad (en az 3 karakter):")
    let nameInp = TextInput(panel, "")
    sizerAdd(sizer, nameLbl.handle, 0, WX_LEFT(), 10)
    sizerAdd(sizer, nameInp.handle, 0, WX_EXPAND(), 3)

    // Email field
    let emailLbl = Label(panel, "E-posta:")
    let emailInp = TextInput(panel, "")
    sizerAdd(sizer, emailLbl.handle, 0, WX_LEFT(), 10)
    sizerAdd(sizer, emailInp.handle, 0, WX_EXPAND(), 3)

    // Age field
    let ageLbl = Label(panel, "Yas (sayi):")
    let ageInp = TextInput(panel, "")
    sizerAdd(sizer, ageLbl.handle, 0, WX_LEFT(), 10)
    sizerAdd(sizer, ageInp.handle, 0, WX_EXPAND(), 3)

    // Status label
    let status = Label(panel, "")
    status.setFgColor(255, 100, 100)
    sizerAdd(sizer, status.handle, 0, WX_ALL(), 5)

    // Validation result list
    let resultList = ListBox(panel)
    sizerAdd(sizer, resultList.handle, 1, WX_EXPAND(), 5)

    let div = Divider(panel)
    sizerAdd(sizer, div.handle, 0, WX_EXPAND(), 8)

    // Validate button
    let validateBtn = Button(panel, "Dogrula ve Kaydet")
    validateBtn.onClick(|_h: i32| {
        resultList.clear()
        let name = nameInp.getText()
        let email = emailInp.getText()
        let age = ageInp.getText()

        resultList.addItem("Ad: kontrol ediliyor...")
        resultList.addItem("E-posta: kontrol ediliyor...")
        resultList.addItem("Yas: kontrol ediliyor...")

        status.setText("Dogrulama tamamlandi!")
        status.setFgColor(100, 200, 100)
    })
    sizerAdd(sizer, validateBtn.handle, 0, WX_ALL(), 8)

    // Clear button
    let clearBtn = Button(panel, "Temizle")
    clearBtn.onClick(|_h: i32| {
        nameInp.setText("")
        emailInp.setText("")
        ageInp.setText("")
        status.setText("")
        resultList.clear()
    })
    sizerAdd(sizer, clearBtn.handle, 0, WX_LEFT(), 10)

    panel.setSizerHandle(sizer)
    win.show()
    appRun()
}
