root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{cpp,h}]
indent_style = space
indent_size = 4

[*.{liva}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json}]
indent_style = space
indent_size = 2

[*.{md}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{toml}]
indent_style = space
indent_size = 4

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.cmake]
indent_style = space
indent_size = 4

[*.{bat,cmd}]
end_of_line = crlf

[*.{sh}]
end_of_line = lf
