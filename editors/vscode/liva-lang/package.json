{
    "name": "liva-lang",
    "displayName": "Liva Language",
    "description": "Full language support for Liva — a modern, compiled language with Swift-like syntax and Rust-style ownership. Provides 18+ LSP features, syntax highlighting, debugging, and diagnostics.",
    "version": "1.0.0",
    "publisher": "liva-lang",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/liva-lang/liva-lang"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Linters",
        "Formatters"
    ],
    "keywords": [
        "liva",
        "compiler",
        "ownership",
        "generics",
        "pattern-matching",
        "llvm",
        "classes",
        "FFI",
        "WASM",
        "JIT",
        "concurrency",
        "benchmarking",
        "test-framework",
        "plugin-system"
    ],
    "activationEvents": [
        "onLanguage:liva",
        "onDebugResolve:liva"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "breakpoints": [
            {
                "language": "liva"
            }
        ],
        "languages": [
            {
                "id": "liva",
                "extensions": [
                    ".liva"
                ],
                "aliases": [
                    "Liva",
                    "liva"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "liva",
                "scopeName": "source.liva",
                "path": "./syntaxes/liva.tmLanguage.json"
            }
        ],
        "debuggers": [
            {
                "type": "liva",
                "label": "Liva Debug",
                "languages": [
                    "liva"
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Path to the .liva source file to debug.",
                                "default": "${file}"
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "description": "Break on the entry point of the program.",
                                "default": false
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "liva",
                        "request": "launch",
                        "name": "Debug Liva Program",
                        "program": "${file}",
                        "stopOnEntry": false
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "Liva: Debug Current File",
                        "description": "Debug the currently open .liva file.",
                        "body": {
                            "type": "liva",
                            "request": "launch",
                            "name": "Debug Liva Program",
                            "program": "^\"\\${file}\"",
                            "stopOnEntry": false
                        }
                    }
                ]
            }
        ],
        "commands": [
            {
                "command": "liva.restartServer",
                "title": "Liva: Restart Server",
                "category": "Liva"
            }
        ],
        "configuration": {
            "title": "Liva",
            "properties": {
                "liva.livacPath": {
                    "type": "string",
                    "default": "livac",
                    "description": "Path to the livac compiler executable used by the LSP server."
                },
                "liva.enableSemanticTokens": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable semantic token highlighting from the LSP server (provides more accurate coloring than TextMate grammar alone)."
                },
                "liva.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace communication between VS Code and the Liva language server."
                }
            }
        }
    },
    "scripts": {
        "compile": "node esbuild.config.mjs",
        "watch": "node esbuild.config.mjs --watch",
        "package": "node esbuild.config.mjs --production && npx vsce package",
        "lint": "tsc --noEmit"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.2.3",
        "@types/vscode": "^1.85.0",
        "esbuild": "^0.27.3",
        "typescript": "^5.3.0"
    }
}
