{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Liva",
    "scopeName": "source.liva",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#char-literal" },
        { "include": "#numbers" },
        { "include": "#test-block" },
        { "include": "#extern-block" },
        { "include": "#for-await" },
        { "include": "#keywords" },
        { "include": "#storage-types" },
        { "include": "#constants" },
        { "include": "#function-definition" },
        { "include": "#struct-definition" },
        { "include": "#class-definition" },
        { "include": "#enum-definition" },
        { "include": "#protocol-definition" },
        { "include": "#impl-definition" },
        { "include": "#type-alias" },
        { "include": "#builtin-functions" },
        { "include": "#function-call" },
        { "include": "#type-annotation" },
        { "include": "#return-type" },
        { "include": "#closure" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.documentation.liva",
                    "match": "///.*$"
                },
                {
                    "name": "comment.line.double-slash.liva",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.liva",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        { "include": "#comments" }
                    ]
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.liva",
                    "begin": "\"\"\"",
                    "end": "\"\"\"",
                    "patterns": [
                        { "include": "#string-escape" },
                        { "include": "#string-interpolation" }
                    ]
                },
                {
                    "name": "string.quoted.double.liva",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "include": "#string-escape" },
                        { "include": "#string-interpolation" }
                    ]
                }
            ]
        },
        "char-literal": {
            "patterns": [
                {
                    "name": "string.quoted.single.char.liva",
                    "match": "'(?:[^'\\\\]|\\\\[nrt\\\\'0]|\\\\u\\{[0-9a-fA-F]+\\})'"
                }
            ]
        },
        "string-escape": {
            "patterns": [
                {
                    "name": "constant.character.escape.liva",
                    "match": "\\\\[nrt\\\\\"'0]"
                },
                {
                    "name": "constant.character.escape.unicode.liva",
                    "match": "\\\\u\\{[0-9a-fA-F]+\\}"
                }
            ]
        },
        "string-interpolation": {
            "patterns": [
                {
                    "name": "meta.interpolation.liva",
                    "begin": "\\\\\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.interpolation.begin.liva" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.section.interpolation.end.liva" }
                    },
                    "patterns": [
                        { "include": "source.liva" }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.liva",
                    "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
                },
                {
                    "name": "constant.numeric.binary.liva",
                    "match": "\\b0[bB][01][01_]*\\b"
                },
                {
                    "name": "constant.numeric.octal.liva",
                    "match": "\\b0[oO][0-7][0-7_]*\\b"
                },
                {
                    "name": "constant.numeric.float.liva",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.liva",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "test-block": {
            "patterns": [
                {
                    "match": "\\b(test)\\s+(\"[^\"]*\")\\s*(?=\\{)",
                    "captures": {
                        "1": { "name": "keyword.control.flow.liva" },
                        "2": { "name": "string.quoted.double.liva" }
                    }
                }
            ]
        },
        "extern-block": {
            "patterns": [
                {
                    "match": "\\b(extern)\\s+(\"C\")\\s*(?=\\{)",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "string.quoted.double.liva" }
                    }
                },
                {
                    "match": "\\b(extern)\\s+(\"C\")\\s+(func)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "string.quoted.double.liva" },
                        "3": { "name": "keyword.declaration.liva" }
                    }
                }
            ]
        },
        "for-await": {
            "patterns": [
                {
                    "match": "\\b(for)\\s+(await)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.flow.liva" },
                        "2": { "name": "keyword.other.async.liva" }
                    }
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flow.liva",
                    "match": "\\b(if|else|while|for|in|match|case|return|break|continue|guard|try|test)\\b"
                },
                {
                    "name": "keyword.declaration.liva",
                    "match": "\\b(func|let|var|const|struct|enum|impl|protocol|import|pub|type|class|extern|macro)\\b"
                },
                {
                    "name": "storage.modifier.liva",
                    "match": "\\b(override|private|dyn|comptime)\\b"
                },
                {
                    "name": "keyword.operator.liva",
                    "match": "\\b(as|ref|mut|where)\\b"
                },
                {
                    "name": "keyword.other.async.liva",
                    "match": "\\b(async|await)\\b"
                },
                {
                    "name": "variable.language.self.liva",
                    "match": "\\b(self|super)\\b"
                },
                {
                    "name": "entity.name.function.special.liva",
                    "match": "\\b(init|deinit)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.true.liva",
                    "match": "\\btrue\\b"
                },
                {
                    "name": "constant.language.boolean.false.liva",
                    "match": "\\bfalse\\b"
                },
                {
                    "name": "constant.language.nil.liva",
                    "match": "\\bnil\\b"
                }
            ]
        },
        "storage-types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.liva",
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|string|void)\\b"
                }
            ]
        },
        "function-definition": {
            "patterns": [
                {
                    "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.function.liva" }
                    }
                },
                {
                    "match": "\\b(async)\\s+(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "keyword.other.async.liva" },
                        "2": { "name": "keyword.declaration.liva" },
                        "3": { "name": "entity.name.function.liva" }
                    }
                }
            ]
        },
        "struct-definition": {
            "patterns": [
                {
                    "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.type.struct.liva" }
                    }
                }
            ]
        },
        "class-definition": {
            "patterns": [
                {
                    "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.type.class.liva" }
                    }
                }
            ]
        },
        "enum-definition": {
            "patterns": [
                {
                    "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.type.enum.liva" }
                    }
                }
            ]
        },
        "protocol-definition": {
            "patterns": [
                {
                    "match": "\\b(protocol)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.type.protocol.liva" }
                    }
                }
            ]
        },
        "impl-definition": {
            "patterns": [
                {
                    "match": "\\b(impl)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.type.liva" }
                    }
                }
            ]
        },
        "type-alias": {
            "patterns": [
                {
                    "match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
                    "captures": {
                        "1": { "name": "keyword.declaration.liva" },
                        "2": { "name": "entity.name.type.alias.liva" }
                    }
                }
            ]
        },
        "builtin-functions": {
            "patterns": [
                {
                    "name": "support.function.builtin.liva",
                    "match": "\\b(print|println|readLine|format|toString|parseInt|parseInt64|parseFloat|charToString|abs|min|max|sqrt|pow|floor|ceil|round|sin|cos|tan|log|log10|len|push|pop|append|sorted|reversed|enumerate|zip|flatten|any|all|count|forEach|map|filter|reduce|strRepeat|strPadLeft|strPadRight|strJoin|strTrim|strTrimLeft|strTrimRight|strContains|strReplace|strSplit|strStartsWith|strEndsWith|strToUpper|strToLower|strReverse|strChars|strLines|randInt|randFloat|sleep|env|exit|args|clock|clockMs|exec|execOutput|processStart|processWait|processKill|processRead|processClose|assert|assertMsg|assertEq|assertEqStr|assertEqFloat|fileRead|fileWrite|fileAppend|fileRemove|fileCopy|isFile|dirList|dirCreate|dirRemove|dirExists|pathJoin|pathDirname|pathBasename|pathExtension|pathExists|pathAbsolute|httpGet|httpPost|httpPut|httpPatch|httpDelete|jsonCreate|jsonSet|jsonSetInt|jsonSetFloat|jsonSetBool|jsonRemove|jsonGet|jsonGetInt|jsonGetFloat|jsonGetBool|jsonGetArray|jsonGetObject|jsonIsValid|jsonKeys|jsonCount|regexCompile|regexTest|regexMatch|regexFind|regexFindAll|regexReplace|regexExec|regexExecGroups|regexFindGroups|regexReplaceCompiled|regexFree|sha256|md5|hmacSha256|base64Encode|base64Decode|hexEncode|hexDecode|crc32|mutexCreate|mutexLock|mutexUnlock|mutexTryLock|mutexFree|atomicCreate|atomicLoad|atomicStore|atomicAdd|atomicSub|atomicCas|atomicFree|channelCreate|channelSend|channelReceive|channelClose|channelLen|channelFree|taskGroupCreate|taskGroupSpawn|taskGroupAwaitAll|taskGroupCancelAll|taskGroupCount|taskGroupFree|taskSelect|withTimeout|schedulerInit|schedulerShutdown|schedulerWorkerCount|asyncFileRead|asyncFileWrite|isCancelled|logDebug|logInfo|logWarn|logError|logSetLevel|dateNow|timeNow|datetimeNow|dateFormat|dateYear|dateMonth|dateDay|dateWeekday|dateTimestamp|dateParse|dateAdd|dateDiff|dateHour|dateMinute|dateSecond|benchStart|benchIter|benchDone|benchReport|benchReset)\\s*(?=\\()"
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.call.liva" }
                    }
                },
                {
                    "match": "\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.method.liva" }
                    }
                }
            ]
        },
        "type-annotation": {
            "patterns": [
                {
                    "match": ":\\s*(?:(\\[)\\s*)?(?:(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|string|void)|(Result|Array|Optional|Map|Set)\\s*<|([A-Z][a-zA-Z0-9_]*))(?:(\\?))?(?:\\s*(\\]))?",
                    "captures": {
                        "1": { "name": "punctuation.definition.array.begin.liva" },
                        "2": { "name": "storage.type.primitive.liva" },
                        "3": { "name": "support.type.collection.liva" },
                        "4": { "name": "entity.name.type.liva" },
                        "5": { "name": "keyword.operator.optional.liva" },
                        "6": { "name": "punctuation.definition.array.end.liva" }
                    }
                }
            ]
        },
        "return-type": {
            "patterns": [
                {
                    "match": "->\\s*(?:(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|string|void)|([A-Z][a-zA-Z0-9_]*))(?:(\\?))?",
                    "captures": {
                        "1": { "name": "storage.type.primitive.liva" },
                        "2": { "name": "entity.name.type.liva" },
                        "3": { "name": "keyword.operator.optional.liva" }
                    }
                }
            ]
        },
        "closure": {
            "patterns": [
                {
                    "match": "\\|",
                    "name": "punctuation.definition.closure.pipe.liva"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.liva",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.liva",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.assignment.compound.liva",
                    "match": "\\+=|-=|\\*=|/=|%="
                },
                {
                    "name": "keyword.operator.assignment.liva",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.liva",
                    "match": "\\+|-|\\*|/|%"
                },
                {
                    "name": "keyword.operator.bitwise.liva",
                    "match": "<<|>>|&|\\||\\^|~"
                },
                {
                    "name": "keyword.operator.nil-coalescing.liva",
                    "match": "\\?\\?"
                },
                {
                    "name": "keyword.operator.optional-chaining.liva",
                    "match": "\\?\\."
                },
                {
                    "name": "keyword.operator.range.liva",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.arrow.liva",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.fat-arrow.liva",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.scope.liva",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.spread.liva",
                    "match": "\\.\\.\\."
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator.comma.liva",
                    "match": ","
                },
                {
                    "name": "punctuation.terminator.semicolon.liva",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.colon.liva",
                    "match": ":"
                },
                {
                    "name": "punctuation.accessor.dot.liva",
                    "match": "\\."
                },
                {
                    "name": "punctuation.section.braces.begin.liva",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.braces.end.liva",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.section.brackets.begin.liva",
                    "match": "\\["
                },
                {
                    "name": "punctuation.section.brackets.end.liva",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.section.parens.begin.liva",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.parens.end.liva",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.definition.annotation.liva",
                    "match": "@"
                },
                {
                    "name": "keyword.operator.wildcard.liva",
                    "match": "\\b_\\b"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.type.liva",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                },
                {
                    "name": "variable.other.liva",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
