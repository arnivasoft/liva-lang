// RuntimeFunctions.def — runtime ABI'nin tek kaynağı.
// LIVA_RT(name, RET, PARAMS)        IRGen decl (native link çözer)
// LIVA_RT_JIT(name, RET, PARAMS)    IRGen decl + JIT REG
// LIVA_RT_VA / LIVA_RT_JIT_VA       varargs varyantları
// PARAMS: RT_ARGS(kod, ...) — parametresiz için RT_ARGS()
// Tüketici, kullanmadığı makroları boş tanımlamak ZORUNDADIR.
//
// Tip kodları (girdilerde bu YALIN yazımla kullanılır): VOID PTR I8 I32 I64 F64
// (IRGen tarafında RtTypeCode enum'una — RT_VOID..RT_F64 — alias makrolarla köprülenir;
//  girdilerde RT_ önekli yazım KULLANMAYIN.)
//
// printf declaration
LIVA_RT_VA(printf, I32, RT_ARGS(PTR))
// String runtime functions
LIVA_RT(liva_str_dup, PTR, RT_ARGS(PTR))
LIVA_RT_JIT(liva_str_concat, PTR, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_equal, I32, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_compare, I32, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_length, I64, RT_ARGS(PTR))
LIVA_RT_JIT(liva_str_byte_length, I64, RT_ARGS(PTR))
LIVA_RT_JIT(liva_i32_to_str, PTR, RT_ARGS(I32))
// liva_char_to_str(i32) -> i8* (char code point to string)
LIVA_RT(liva_char_to_str, PTR, RT_ARGS(I32))
LIVA_RT_JIT(liva_f64_to_str, PTR, RT_ARGS(F64))
LIVA_RT_JIT(liva_bool_to_str, PTR, RT_ARGS(I8))
LIVA_RT_JIT(liva_i64_to_str, PTR, RT_ARGS(I64))
// String method runtime functions
LIVA_RT_JIT(liva_str_contains, I8, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_starts_with, I8, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_ends_with, I8, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_index_of, I64, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_substring, PTR, RT_ARGS(PTR, I64, I64))
LIVA_RT_JIT(liva_str_trim, PTR, RT_ARGS(PTR))
LIVA_RT_JIT(liva_str_to_upper, PTR, RT_ARGS(PTR))
LIVA_RT_JIT(liva_str_to_lower, PTR, RT_ARGS(PTR))
LIVA_RT_JIT(liva_str_replace, PTR, RT_ARGS(PTR, PTR, PTR))
LIVA_RT_JIT(liva_str_split, PTR, RT_ARGS(PTR, PTR, PTR))
// Type conversion: string → number (returns i8 success flag, writes to output ptr)
LIVA_RT_JIT(liva_str_parse_i32, I8, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_parse_i64, I8, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_str_parse_f64, I8, RT_ARGS(PTR, PTR))
