LIVA_RT_JIT(liva_file_open, PTR, RT_ARGS(PTR, PTR))
LIVA_RT_JIT(liva_file_close, VOID, RT_ARGS(PTR))
LIVA_RT_JIT(liva_file_read_line, PTR, RT_ARGS(PTR))
